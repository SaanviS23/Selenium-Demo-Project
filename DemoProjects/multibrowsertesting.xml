<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="multibrowsertesting" parallel="tests">

  <test name="Chrome Test">
  <parameter name="browser" value="chrome"></parameter>
    <classes>
     <class name="testscripts.LoginTest">
     <methods>
     <include name="verifytheUserIsAbleToLoginUsingValidCredentials"></include>
     <include name="verifytheUserIsAbleToLoginUsingInValidUserNameandValidPassword"></include>
     </methods>
     </class>
    </classes>
  </test> <!-- Test -->
  
    <test name="Edge Test">
    <parameter name="browser" value="edge"></parameter>
    <classes>
     <class name="testscripts.LoginTest">
     <methods>
     <include name="verifytheUserIsAbleToLoginUsingValidCredentials"></include>
     <include name="verifytheUserIsAbleToLoginUsingInValidUserNameandValidPassword"></include>
     </methods>
     </class>
    </classes>
  </test> <!-- Test -->
  
</suite> <!-- Suite -->
